{
  "name": "eventudio-event-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "vite",
    "dev:marketing": "pnpm --dir apps/marketing dev",
    "dev:admin": "pnpm --dir apps/admin dev",
    "dev:docs": "pnpm --dir apps/docs dev",
    "dev:api": "pnpm --dir apps/api dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bootstrap": "corepack enable && pnpm install --frozen-lockfile",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "check:all": "pnpm -r --filter './packages/*' --if-present check && pnpm check && pnpm -r --filter './apps/*' --if-present check",
    "test": "vitest",
    "test:watch": "vitest",
    "test:all": "pnpm test -- --run && pnpm -r --filter './apps/*' --if-present test && pnpm -r --filter './packages/*' --if-present test"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  }
}
